# Required
COOKIE_SECRET=                  # generate with: openssl rand -hex 32

# Optional — OpenAI Whisper voice transcription
OPENAI_API_KEY=

# Optional — Ollama AI daily recaps (only needed if running with --profile ollama)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# Optional — daily email digest and healthcheck alerts
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
